{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["detected", "risk_score", "issues", "entity_type", "summary"],
  "properties": {
    "detected": { "type": "boolean" },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_level": { "type": "string" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "severity", "title", "evidence", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["FORBIDDEN_TERM", "OVERKILL_CONTROL", "INCONSISTENCY", "MISSING_SECTION"]
          },
          "severity": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
          "title": { "type": "string" },
          "evidence": { "type": ["string", "null"] },
          "recommendation": { "type": "string" },
          "sfc_ref_id": { "type": ["string", "null"] },
          "sfc_ref_text": { "type": ["string", "null"] }
        }
      }
    },
    "entity_type": { "type": "string" },
    "summary": { "type": "string" },
    "total_issues": { "type": "integer" },
    "high_severity": { "type": "integer" },
    "medium_severity": { "type": "integer" },
    "low_severity": { "type": "integer" }
  }
}
